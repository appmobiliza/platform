{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "plan": {
      "description": "Orquestrador principal do projeto Mobiliza. Coordena o fluxo SDD+TLC e delega para subagents.",
      "mode": "primary",
      "prompt": "{file:agents/plan.md}",
      "permission": {
        "edit": "allow",
        "bash": {
          "git add*": "ask",
          "git commit*": "ask",
          "git push*": "ask",
          "git merge*": "ask",
          "gh *": "ask",
          "*": "allow"
        },
        "skill": "allow",
        "webfetch": "ask"
      }
    },
    "build": {
      "description": "Executor de tarefas do projeto Mobiliza. Implementa código seguindo TLC Pattern.",
      "mode": "primary",
      "prompt": "{file:agents/build.md}",
      "permission": {
        "edit": "allow",
        "bash": {
          "git add*": "ask",
          "git commit*": "ask",
          "git push*": "ask",
          "gh *": "ask",
          "rm *": "ask",
          "*": "allow"
        },
        "skill": "allow"
      }
    },
    "mobiliza-test": {
      "description": "Subagent especializado em criar testes unitários e de integração seguindo TDD.",
      "mode": "subagent",
      "prompt": "{file:agents/mobiliza-test.agent.md}",
      "permission": {
        "edit": "allow",
        "bash": {
          "git *": "ask",
          "*": "allow"
        },
        "skill": "allow"
      }
    },
    "mobiliza-backend": {
      "description": "Subagent especializado em backend Node.js, tRPC, Drizzle e PostgreSQL.",
      "mode": "subagent",
      "prompt": "{file:agents/mobiliza-backend.agent.md}",
      "permission": {
        "edit": "allow",
        "bash": {
          "git *": "ask",
          "rm *": "ask",
          "*": "allow"
        },
        "skill": "allow"
      }
    },
    "mobiliza-frontend": {
      "description": "Subagent especializado em Next.js, React e interfaces acessíveis.",
      "mode": "subagent",
      "prompt": "{file:agents/mobiliza-frontend.agent.md}",
      "permission": {
        "edit": "allow",
        "bash": {
          "git *": "ask",
          "rm *": "ask",
          "*": "allow"
        },
        "skill": "allow"
      }
    },
    "mobiliza-debug": {
      "description": "Subagent especializado em diagnóstico de bugs e problemas de runtime.",
      "mode": "subagent",
      "prompt": "{file:agents/mobiliza-debug.agent.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "git *": "ask",
          "*": "allow"
        },
        "skill": "allow",
        "webfetch": "allow"
      }
    },
    "mobiliza-explorer": {
      "description": "Subagent especializado em explorar e mapear codebases. Investiga com precisão, documenta descobertas em .notebook/.",
      "mode": "subagent",
      "prompt": "{file:agents/mobiliza-explorer.agent.md}",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "skill": "allow",
        "webfetch": "allow"
      }
    },
    "mobiliza-architect": {
      "description": "Subagent especializado em design de sistemas e diagramas de arquitetura.",
      "mode": "subagent",
      "prompt": "{file:agents/mobiliza-architect.agent.md}",
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "skill": "allow"
      }
    },
    "mobiliza-docs": {
      "description": "Subagent especializado em documentação e preservação de contexto.",
      "mode": "subagent",
      "prompt": "{file:agents/mobiliza-docs.agent.md}",
      "permission": {
        "edit": "allow",
        "bash": "deny",
        "skill": "allow"
      }
    }
  },
  "permission": {
    "skill": {
      "tlc-spec-driven": "allow",
      "commit-helper": "allow",
      "caveman": "allow",
      "codenavi": "allow",
      "coding-guidelines": "allow",
      "senior-backend": "allow",
      "senior-architect": "allow",
      "frontend-design": "allow",
      "docs-writer": "allow",
      "unit-testing-mastery": "allow",
      "browser-automation": "allow",
      "sequential-thinking": "allow",
      "mermaid-studio": "allow",
      "neon-postgres": "allow"
    }
  }
}