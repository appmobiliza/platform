# Banco de dados — obtenha a connection string no dashboard do Neon
# Formato: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# Origens confiáveis para o Better Auth (separadas por vírgula)
# Em desenvolvimento: http://localhost:3000,http://localhost:8081
# Em produção: https://mobiliza.vercel.app,exp://...
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8081

# Ambiente — afeta o logger do Drizzle e outros comportamentos
NODE_ENV=development
